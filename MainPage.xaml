<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BeepBeepBeep.MainPage"
             BackgroundColor="#0F0F1A">

    <Grid>

        <!-- Main content -->
        <ScrollView>
            <VerticalStackLayout Padding="30,50,30,30" Spacing="28">

                <Label Text="Beep...Beep...Beep"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />

                <!-- Pre-session panel -->
                <VerticalStackLayout x:Name="PreSessionPanel" Spacing="22">

                    <Label x:Name="SettingsSummaryLabel"
                           TextColor="#888888"
                           FontSize="28"
                           HorizontalTextAlignment="Center" />

                    <Button Text="START"
                            FontSize="20" FontAttributes="Bold"
                            BackgroundColor="#FF4757"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="64"
                            Margin="0,10,0,0"
                            Clicked="OnStartClicked" />

                    <Button Text="⚙  SETTINGS"
                            FontSize="14" FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            TextColor="#555577"
                            CornerRadius="12"
                            HeightRequest="44"
                            Clicked="OnSettingsClicked" />

                </VerticalStackLayout>

                <!-- Active Panel -->
                <VerticalStackLayout x:Name="ActivePanel" IsVisible="False" Spacing="16">

                    <Label x:Name="RepCounterLabel"
                           Text="Rep 1 of 5"
                           FontSize="18"
                           TextColor="#888888"
                           HorizontalTextAlignment="Center" />

                    <Label x:Name="PhaseLabel"
                           Text="PRIMARY"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="#FF4757"
                           HorizontalTextAlignment="Center"
                           CharacterSpacing="3" />

                    <Label x:Name="CountdownLabel"
                           Text="01:00"
                           FontSize="96" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           Margin="0,24" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0" x:Name="PauseButton"
                                Text="PAUSE"
                                FontSize="20" FontAttributes="Bold"
                                BackgroundColor="#1E1E32"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="64"
                                Clicked="OnPauseClicked" />
                        <Button Grid.Column="1" Text="STOP"
                                FontSize="20" FontAttributes="Bold"
                                BackgroundColor="#3A3A5C"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="64"
                                Clicked="OnStopClicked" />
                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Dimming overlay -->
        <BoxView x:Name="DimOverlay"
                 BackgroundColor="#CC000000"
                 IsVisible="False"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Settings drawer -->
        <VerticalStackLayout x:Name="SettingsDrawer"
                             VerticalOptions="End"
                             BackgroundColor="#1A1A2E"
                             Padding="30,20,30,44"
                             Spacing="22"
                             IsVisible="False">

            <BoxView HeightRequest="4" WidthRequest="44"
                     BackgroundColor="#444466"
                     HorizontalOptions="Center"
                     CornerRadius="2"
                     Margin="0,0,0,4" />

            <Label Text="SETTINGS"
                   TextColor="#888888"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="1.5" />

            <!-- Primary Time -->
            <VerticalStackLayout Spacing="10">
                <Label Text="PRIMARY TIME (seconds)"
                       TextColor="#888888"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="1.5" />
                <Grid ColumnDefinitions="60,*,60" ColumnSpacing="10" HeightRequest="64">
                    <Button Grid.Column="0" Text="−" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnPrimaryDecrement" CornerRadius="10"
                            HeightRequest="64" />
                    <Entry Grid.Column="1" x:Name="PrimaryTimeEntry"
                           Text="10"
                           FontSize="36" FontAttributes="Bold"
                           TextColor="White"
                           BackgroundColor="#0F0F1A"
                           HorizontalTextAlignment="Center"
                           Keyboard="Numeric"
                           ReturnType="Done"
                           TextChanged="OnPrimaryTimeChanged" />
                    <Button Grid.Column="2" Text="+" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnPrimaryIncrement" CornerRadius="10"
                            HeightRequest="64" />
                </Grid>
            </VerticalStackLayout>

            <!-- Secondary Time -->
            <VerticalStackLayout Spacing="10">
                <Label Text="SECONDARY TIME (seconds)"
                       TextColor="#888888"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="1.5" />
                <Grid ColumnDefinitions="60,*,60" ColumnSpacing="10" HeightRequest="64">
                    <Button Grid.Column="0" Text="−" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnSecondaryDecrement" CornerRadius="10"
                            HeightRequest="64" />
                    <Entry Grid.Column="1" x:Name="SecondaryTimeEntry"
                           Text="5"
                           FontSize="36" FontAttributes="Bold"
                           TextColor="White"
                           BackgroundColor="#0F0F1A"
                           HorizontalTextAlignment="Center"
                           Keyboard="Numeric"
                           ReturnType="Done"
                           TextChanged="OnSecondaryTimeChanged" />
                    <Button Grid.Column="2" Text="+" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnSecondaryIncrement" CornerRadius="10"
                            HeightRequest="64" />
                </Grid>
            </VerticalStackLayout>

            <!-- Repetitions -->
            <VerticalStackLayout Spacing="10">
                <Label Text="REPETITIONS"
                       TextColor="#888888"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="1.5" />
                <Grid ColumnDefinitions="60,*,60" ColumnSpacing="10" HeightRequest="64">
                    <Button Grid.Column="0" Text="−" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnRepsDecrement" CornerRadius="10"
                            HeightRequest="64" />
                    <Label Grid.Column="1" x:Name="RepsLabel"
                           Text="5"
                           FontSize="36" FontAttributes="Bold"
                           TextColor="White"
                           BackgroundColor="#0F0F1A"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="2" Text="+" FontSize="28"
                            BackgroundColor="#0F0F1A" TextColor="White"
                            Clicked="OnRepsIncrement" CornerRadius="10"
                            HeightRequest="64" />
                </Grid>
            </VerticalStackLayout>

            <!-- Reminder Beep -->
            <VerticalStackLayout Spacing="10">
                <Label Text="REMINDER BEEP"
                       TextColor="#888888"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="1.5" />
                <Grid ColumnDefinitions="*,Auto" Padding="10,0">
                    <Label Grid.Column="0"
                           Text="Beep during primary countdown"
                           TextColor="White"
                           FontSize="14"
                           VerticalTextAlignment="Center" />
                    <Switch Grid.Column="1"
                            x:Name="ReminderSwitch"
                            OnColor="#FF4757"
                            Toggled="OnReminderToggled" />
                </Grid>

                <VerticalStackLayout x:Name="ReminderIntervalSection" IsVisible="False" Spacing="10">
                    <Label Text="REMINDER INTERVAL (seconds)"
                           TextColor="#888888"
                           FontSize="12"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           CharacterSpacing="1.5" />
                    <Grid ColumnDefinitions="60,*,60" ColumnSpacing="10" HeightRequest="64">
                        <Button Grid.Column="0" Text="−" FontSize="28"
                                BackgroundColor="#0F0F1A" TextColor="White"
                                Clicked="OnReminderIntervalDecrement" CornerRadius="10"
                                HeightRequest="64" />
                        <Entry Grid.Column="1" x:Name="ReminderIntervalEntry"
                               Text="10"
                               FontSize="36" FontAttributes="Bold"
                               TextColor="White"
                               BackgroundColor="#0F0F1A"
                               HorizontalTextAlignment="Center"
                               Keyboard="Numeric"
                               ReturnType="Done"
                               TextChanged="OnReminderIntervalChanged" />
                        <Button Grid.Column="2" Text="+" FontSize="28"
                                BackgroundColor="#0F0F1A" TextColor="White"
                                Clicked="OnReminderIntervalIncrement" CornerRadius="10"
                                HeightRequest="64" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="DONE"
                    FontSize="16" FontAttributes="Bold"
                    BackgroundColor="#FF4757"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,8,0,0"
                    Clicked="OnSettingsDoneClicked" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>
